# Backend Configuration

# Enable Firestore (true for production, false/omit for in-memory testing)
USE_FIRESTORE=false

# Node Environment
NODE_ENV=development

# Server Port
PORT=4000

# JWT Secret (used for signing tokens)
JWT_SECRET=change_me_to_a_random_value_in_production

# Firebase Emulator (for local testing with Firestore)
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# Notification Settings
ENABLE_NOTIFICATIONS=true
NOTIFICATION_FREQUENCY_SECONDS=60
